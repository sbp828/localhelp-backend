[Unit]
Description=LocalHelp Backend Service
After=network.target

[Service]
User=localhelp
WorkingDirectory=/app/localhelp-backend
ExecStart=/usr/bin/java -jar /app/localhelp-backend/app.jar

Environment="DB_HOST={{ login_host }}"
Environment="DB_USER={{ login_user }}"
Environment="DB_PASSWORD={{ login_password }}"



SuccessExitStatus=143
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target